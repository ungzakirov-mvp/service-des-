# ===========================================
# Novum Tech Bot - Конфигурация
# ===========================================

# Telegram Bot Token от @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Ваш Telegram ID (получите у @userinfobot)
ADMIN_CHAT_ID=your_telegram_id_here

# ID канала для публикации товаров (бот должен быть админом)
OUTPUT_CHANNEL_ID=your_output_channel_id_here

# ID каналов поставщиков (бот должен быть админом)
SUPPLIER_CHANNEL_1=-1001234567890
SUPPLIER_CHANNEL_2=-1009876543210
SUPPLIER_CHANNEL_3=-100111222333
SUPPLIER_CHANNEL_4=-100444555666
SUPPLIER_CHANNEL_5=-100777888999

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# Опционально: период проверки (по умолчанию каждую минуту)
CHECK_INTERVAL=60000

# Опционально: включить автопостинг
AUTO_POST=true

# Опционально: минимальная цена для фильтрации (в суммах)
MIN_PRICE=100000
